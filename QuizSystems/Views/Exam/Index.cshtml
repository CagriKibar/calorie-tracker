@model IEnumerable<QuizSystems.Models.OnlineExam>

@{
    ViewData["Title"] = "Index";
}

<h1> Konusarak Ogren Online Quiz Systems</h1>
<h2>Welcome</h2>
<br />

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
<table class="table">
    
    <tbody>
@foreach (var item in Model) {
        <tr>
             <td>
                @Html.DisplayFor(modelItem => item.WebHead) 
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.WebContent) 
            </td>
           
            <td>
                @Html.DisplayFor(modelItem => item.QuizId) @Html.DisplayFor(modelItem => item.Question) ?
            </td>
           
            <td>
                @Html.DisplayFor(modelItem => item.Options1)
                <input type="radio" id="options1" name="@Html.DisplayFor(modelItem=>item.QuizId)" class="rb" value="@Html.DisplayFor(modelItem => item.Options1)"/>
                @Html.DisplayFor(modelItem => item.Options2)
                <input type="radio" id="options1" name="@Html.DisplayFor(modelItem=>item.QuizId)" class="rb" value="@Html.DisplayFor(modelItem => item.Options2)"/>
                 @Html.DisplayFor(modelItem => item.Options3)
                  <input type="radio" id="options1" name="@Html.DisplayFor(modelItem=>item.QuizId)" class="rb" value="@Html.DisplayFor(modelItem => item.Options3)"/>
                  @Html.DisplayFor(modelItem => item.Options4)
                   <input type="radio" id="options1" name="@Html.DisplayFor(modelItem=>item.QuizId)" class="rb" value="@Html.DisplayFor(modelItem => item.Options4)"/>
              </td>
            </tr>

            <tr>

            <td>
              <label id="correctans" name="@Html.DisplayFor(modelItem=>item.QuizId)" class="rb" style="display:none; color:forestgreen"><b>@Html.DisplayFor(modelItem => item.Correctans)</b></label>  
            </td>
            
        </tr>
}
    </tbody>
</table>
<button type="button" id="butexam" class="btn btn-success" onclick="displayresult()">Submit</button>
<label id="Usranswes"></label>

<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

<script>
    $(document).ready(function(){
        $("butexam").click(function(){
            $(".rb").show();
            $(".rb").attr("disabled",true);
        })
    });
    function displayresult(){
        document.getElementById(Usranswes).innerHTML="";
        var results=document.getElementsByTagName('input');
        for(i=0; i<results.length; i++ ){
            if(results[i].type=="radio"){
                if(results[i].checked){
                    document.getElementById("Usranswes").innerHTML + "Q"+ results[i].name+")"+"The Selected Answer Is"+results[i].value+"<br/>";
                }
            }
        }

    }


    
    }
</script>